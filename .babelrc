{
  "comments": false,
  "env": {
    "main": {
      "presets": [
        ["@babel/preset-env", {
          "targets": { "node": "current" }
        }]
      ],
      "plugins": ["@babel/plugin-transform-runtime"]
    },
    "renderer": {
      "presets": [
        ["@babel/preset-env", {
          "modules": false
        }]
      ],
      "plugins": ["@babel/plugin-transform-runtime"]
    },
    "web": {
      "presets": [
        ["@babel/preset-env", {
          "modules": false
        }]
      ],
      "plugins": ["@babel/plugin-transform-runtime"]
    }
  }
}
